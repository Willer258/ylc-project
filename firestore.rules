rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === EVENTS ===
    match /events/{eventId} {
      allow read: if true;
      allow write: if true; // Admin writes from client (OTP-authenticated)

      match /teams/{teamId} {
        allow read: if true;
        allow create: if true;  // Admin creates teams
        allow update: if true;  // Join, vote, etc.
        allow delete: if true;  // Admin deletes

        match /members/{memberId} {
          allow read: if true;
          allow create, update: if true;
          allow delete: if true;
        }

        match /scans/{scanId} {
          allow read: if true;
          allow create: if true;
        }
      }

      match /members/{memberId} {
        allow read: if true;
        allow create, update: if true;
      }

      match /phrases/{phraseId} {
        allow read: if true;
        allow write: if true;

        match /words/{wordId} {
          allow read: if true;
          allow write: if true;
        }
      }

      match /photos/{photoId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if true; // Admin moderation
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if true;
      }
    }

    // === GAME TEMPLATES ===
    match /gameTemplates/{templateId} {
      allow read: if true;
      allow write: if true; // Admin creates/edits
    }

    // === GAME INSTANCES ===
    match /gameInstances/{gameId} {
      allow read: if true;
      allow write: if true; // Admin controls + API updates leaderboard
    }

    // === GAME PROGRESS ===
    match /gameProgress/{gameId}/teams/{teamId} {
      allow read: if true;
      allow write: if true; // API updates + QR scan updates
    }

    // === QR SLOTS ===
    match /qrSlots/{slotId} {
      allow read: if true;
      allow write: if true; // Admin + scan tracking
    }

    // === ANNOUNCEMENTS ===
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if true; // Admin posts
    }

    // === GUIDE MESSAGES ===
    match /guideMessages/{messageId} {
      allow read: if true;
      allow write: if true;
    }

    // === ADMIN REQUESTS (OTP) ===
    match /adminRequests/{requestId} {
      allow read: if true;  // Login page reads its own request
      allow create: if true; // Anyone can request
      allow update: if true; // Approve/verify
      allow delete: if true; // Cleanup
    }
  }
}
